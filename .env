# Master alvo (quando existir um master conhecido)
MASTER_IP=10.62.206.23
MASTER_PORT=8000
SERVER_UUID=SRV-MASTER

# Identidade do worker atual
WORKER_UUID=WRK-01-ALPHA

# Host/porta onde este worker fica disponível para status/election e para se tornar master
# WORKER_HOST é opcional; se não informado, o IP local será detectado automaticamente
# WORKER_HOST=10.62.206.23
WORKER_PORT=8000

# Threshold para detectar downtime do master
HEARTBEAT_THRESHOLD=4
HEARTBEAT_INTERVAL=5
WORKER_STATUS_TIMEOUT=3

# Descoberta dinâmica de peers para eleição
# WORKER_PEERS pode ser deixado vazio para usar apenas broadcast
WORKER_PEERS=
WORKER_DISCOVERY_ENABLED=true
WORKER_BROADCAST_ADDRESS=255.255.255.255
WORKER_DISCOVERY_TIMEOUT=2
