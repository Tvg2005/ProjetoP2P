# UUID do master alvo — usado na descoberta por broadcast
SERVER_UUID=SRV-MASTER

# Porta TCP do servidor master
MASTER_PORT=8000

# Porta UDP de descoberta (padrão = MASTER_PORT + 1)
DISCOVERY_PORT=8001

# Identidade do worker atual
# WORKER_UUID é OPCIONAL: se vazio ou ausente, um UUID é gerado automaticamente
# e salvo em .worker_id para persistência entre reinicializações.
# Descomente e defina para forçar um UUID fixo:
# WORKER_UUID=WRK-MEU-NO
WORKER_PORT=8000

# Threshold para detectar downtime do master
HEARTBEAT_THRESHOLD=4
HEARTBEAT_INTERVAL=5
WORKER_STATUS_TIMEOUT=3

# ── Eleição via broadcast ─────────────────────────────────────────────────────
# Tempo de espera após detectar master inativo antes de iniciar eleição (segundos)
ELECTION_DELAY=5
# Janela de coleta de respostas ELECTION_BROADCAST (segundos)
ELECTION_COLLECT_TIMEOUT=5

# Descoberta de peers para eleição (agora via broadcast — campos abaixo para legado)
WORKER_PEERS=
WORKER_DISCOVERY_ENABLED=true

# Endereço de broadcast (vazio = auto-detecta /24 do IP local)
# WORKER_BROADCAST_ADDRESS=10.62.206.255
WORKER_DISCOVERY_TIMEOUT=2
